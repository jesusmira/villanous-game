# Plantilla de variables de entorno. Copia a .env.local y rellena los valores.
# .env.local está gitignored (*.local); este .env.example sí se commitea, SIN secretos.

# Cliente (navegador)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Solo para el script local de subida de imágenes (Node). NUNCA commitear su valor real.
SUPABASE_SERVICE_ROLE_KEY=
